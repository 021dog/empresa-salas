# Supabase Configuration
# VITE_ prefix is required for client-side access
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Resend API Key (Server-side only)
RESEND_API_KEY="re_..."

# Sentry DSN (Client & Server)
VITE_SENTRY_DSN="https://...@...ingest.sentry.io/..."

# n8n Webhook URL (for automations)
N8N_WEBHOOK_URL="https://your-n8n-instance/webhook/..."

# Gemini API Key (Existing)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL (Existing)
APP_URL="MY_APP_URL"

# Google OAuth Setup (Server-side)
# Used for initial configuration and references
VITE_GOOGLE_CLIENT_ID="868147469607-vqf57314u25u44uj5l14f57s9tc80qf9.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret-aqui"
